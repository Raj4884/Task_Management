# ============================================
# LogSentry - Distributed Log Analysis System
# Environment Configuration
# ============================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=logsentry
POSTGRES_USER=logsentry
POSTGRES_PASSWORD=logsentry_secret_2024

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Redis Streams ---
REDIS_STREAM_NAME=logs:raw
REDIS_CONSUMER_GROUP=log-processors
REDIS_DEAD_LETTER_STREAM=logs:dead-letter

# --- JWT Auth ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Service URLs (internal Docker network) ---
API_GATEWAY_URL=http://api-gateway:8000
INGESTION_SERVICE_URL=http://log-ingestion:8001
LOG_PROCESSOR_URL=http://log-processor:8002
ANOMALY_SERVICE_URL=http://anomaly-detection:8003
QUERY_ENGINE_URL=http://query-engine:8004

# --- Service Ports (external) ---
API_GATEWAY_PORT=8000
DASHBOARD_PORT=8080

# --- Log Simulator ---
SIMULATOR_RATE=10
SIMULATOR_SERVICES=auth-service,payment-service,order-service,user-service,notification-service
SIMULATOR_ERROR_SPIKE_INTERVAL=300

# --- Anomaly Detection ---
ANOMALY_CONTAMINATION=0.05
ANOMALY_RETRAIN_INTERVAL_HOURS=6
ANOMALY_WINDOW_MINUTES=5

# --- General ---
LOG_LEVEL=INFO
ENVIRONMENT=development
